{
  "name": "@tkawen/liqaa-react",
  "version": "1.0.2",
  "description": "React hooks and components for LIQAA Cloud — drop-in video calls + messaging",
  "keywords": [
    "liqaa",
    "react",
    "video",
    "video-call",
    "webrtc",
    "messaging",
    "chat",
    "hooks",
    "components",
    "tkawen",
    "algeria"
  ],
  "homepage": "https://github.com/tkawen/packages/tree/main/packages/liqaa-react#readme",
  "bugs": {
    "url": "https://github.com/tkawen/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkawen/packages.git",
    "directory": "packages/liqaa-react"
  },
  "license": "MIT",
  "author": "Hartem Yaakoub",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --minify --external react",
    "dev": "tsup src/index.tsx --format esm,cjs --dts --watch --external react",
    "test": "echo 'no tests yet'"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@tkawen/liqaa-js": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false
}
